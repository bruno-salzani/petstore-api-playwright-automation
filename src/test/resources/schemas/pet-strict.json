{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "id",
    "name",
    "photoUrls",
    "status"
  ],
  "properties": {
    "id": {
      "type": "integer"
    },
    "name": {
      "type": "string"
    },
    "photoUrls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
